# FamilyCircle environment variables
# Copy to .env and customize for your deployment

# Database path (SQLite file location)
DATABASE_PATH=/data/familycircle.db

# Server port
PORT=8080

# Debug mode (set to "true" for development — disables Secure cookie flag)
DEBUG=false

# Log level
LOG_LEVEL=info

# Timezone
TZ=America/New_York
